# Copy to .env and fill in. The script also accepts these as CLI flags or as
# environment variables exported in your shell. (.env is gitignored.)

# --- Google Cloud Storage ---
GCS_BUCKET=doorstepai-track-chunker
# Path to a service-account JSON key (relative paths resolve to this folder).
# Omit to use Application Default Credentials (GOOGLE_APPLICATION_CREDENTIALS / gcloud).
GCS_CREDENTIALS_PATH=./gcs-key.json

# --- MongoDB ---
MONGO_URI=mongodb+srv://USER:PASSWORD@HOST/?retryWrites=true&w=majority
MONGO_DB=main
MONGO_COLLECTION=tracking_sessions_v3
